{
  "name": "@wytcab/nousboot",
  "version": "0.2.1",
  "description": "Pre-flight briefings for agentic coding sessions. Stop opening cold sessions with your agents.",
  "license": "MIT",
  "author": "Vilhelm Drosjer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wytcab/nousboot.git"
  },
  "homepage": "https://github.com/wytcab/nousboot#readme",
  "bugs": {
    "url": "https://github.com/wytcab/nousboot/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nousboot": "./dist/cli.js",
    "nousboot-mcp": "./dist/mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js dist/mcp.js",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "node --test --import tsx tests/lens.test.ts tests/mcp.test.ts",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@wytcab/projection-core": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agent-tooling",
    "claude-code",
    "claude-desktop",
    "cursor",
    "mcp",
    "paperclip",
    "briefing",
    "cognitive-primitives"
  ]
}
